{
  "name": "life",
  "version": "1.0.0",
  "type": "module",
  "description": "Conway's Game of Life, playable in the browser",
  "main": "index.js",
  "scripts": {
    "format": "f () { prettier --write \"${@:-.}\"; }; f",
    "format:list-different": "prettier --list-different .",
    "test": "eslint && mocha tests/unit",
    "watch": "f () { nodemon --no-colors --quiet --watch life/ --watch tests/ --ext '' --exec \"${@:-npm run --silent test --}\"; }; f",
    "start": "browser-sync start --server life/ --port 3000 --no-open",
    "start:dev": "browser-sync start --server life/ --watch life/ --port 8080"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaf7C7/life.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jaf7C7/life/issues"
  },
  "homepage": "https://github.com/jaf7C7/life#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "browser-sync": "^3.0.4",
    "chai": "^6.2.2",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "mocha": "^11.3.0",
    "nodemon": "^3.1.14",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0"
  }
}
